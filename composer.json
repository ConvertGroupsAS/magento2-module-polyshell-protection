{
    "name": "aregowe/magento2-module-polyshell-protection",
    "version": "1.3.3",
    "description": "Comprehensive defense-in-depth module that closes the PolyShell unrestricted file upload vulnerability (APSB25-94) in Adobe Commerce and Magento Open Source.",
    "require": {
        "php": "^7.2 || ^7.4 || ^8.0 || ^8.1 || ^8.2 || ^8.3",
        "magento/framework": "^102 || ^103"
    },
    "replace": {
        "markshust/magento2-module-polyshell-patch": "*"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "phpunit/phpunit": "^10.5"
    },
    "type": "magento2-module",
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Aregowe\\PolyShellProtection\\": ""
        }
    },
    "repositories": [{
        "name": "magento",
        "type": "composer",
        "url": "https://repo.magento.com/"
    }]
}
